# Copy to .env and fill in after creating a Twilio account.
# https://console.twilio.com

PORT=3000

# Public URL Twilio uses to reach your app (ngrok HTTPS URL while developing locally).
# Example: https://abc123.ngrok-free.app
BASE_URL=

# From Twilio Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Set to true once BASE_URL is your real ngrok/production URL
TWILIO_VALIDATE_WEBHOOKS=false
